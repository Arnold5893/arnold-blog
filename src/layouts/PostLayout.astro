---
/**
 * PostLayout.astro — 文章详情页布局（含悬浮 TOC、Giscus 评论）
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import TOC from '../components/blog/TOC.astro';
import Comments from '../components/blog/Comments.astro';
import { getReadingTime } from '../utils/reading-time';

interface RelatedPost {
  id: string;
  title: string;
  date: string;
  tags: string[];
}

interface Props {
  title: string;
  date: string;
  tags: string[];
  description: string;
  rawContent: string;
  relatedPosts?: RelatedPost[];
}

const { title, date, tags, description, rawContent, relatedPosts = [] } = Astro.props;
const readingTime = getReadingTime(rawContent);

// 格式化日期
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 relative">
    <div class="flex gap-10">
      <!-- 文章正文 -->
      <article class="flex-1 min-w-0">
        <!-- 文章头部 -->
        <header class="mb-10">
          <h1 class="text-3xl sm:text-4xl font-bold font-['Playfair_Display',serif] leading-tight mb-4
                     text-[#2D2D2D] dark:text-[#FFFAF8]">
            {title}
          </h1>
          <div class="flex flex-wrap items-center gap-3 text-sm
                      text-[#9CA3AF] dark:text-[#7070a0]">
            <span>{formattedDate}</span>
            <span>·</span>
            <span>{readingTime}阅读</span>
            {tags.length > 0 && (
              <>
                <span>·</span>
                <div class="flex flex-wrap gap-2">
                  {tags.map(tag => (
                    <a
                      href={`/blog?tag=${tag}`}
                      class="px-2 py-0.5 rounded-full text-xs transition-colors
                             bg-[#FFF0EE] dark:bg-[#2a1520]
                             text-[#F4A7B9] dark:text-[#D4919F]
                             hover:bg-[#F4A7B9] dark:hover:bg-[#D4919F]
                             hover:text-white dark:hover:text-white"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              </>
            )}
          </div>
          <hr class="mt-6 border-[#F3E8E8] dark:border-[#2a2a40]" />
        </header>

        <!-- 文章正文（由父页面通过 slot 注入） -->
        <div class="prose-blog">
          <slot />
        </div>

        <!-- 上下篇导航（由父页面通过 prev/next slot 注入） -->
        <slot name="nav" />

        <!-- 评论区 -->
        <div class="mt-12">
          <Comments />
        </div>
      </article>

      <!-- 右侧悬浮侧边栏（桌面端） -->
      <aside class="hidden xl:block w-56 shrink-0">
        <div class="sticky top-24 max-h-[calc(100vh-8rem)] flex flex-col">
          <!-- 标签栏 -->
          <div class="flex gap-1 mb-3 border-b border-[#F3E8E8] dark:border-[#2a2a40] pb-2">
            <button
              id="tab-toc"
              class="sidebar-tab px-2 py-1 text-xs font-semibold rounded transition-colors
                     text-[#F4A7B9] bg-[#FFF0EE] dark:bg-[#2a1520] dark:text-[#D4919F]"
              data-target="panel-toc"
            >目录</button>
            {relatedPosts.length > 0 && (
              <button
                id="tab-related"
                class="sidebar-tab px-2 py-1 text-xs font-semibold rounded transition-colors
                       text-[#9CA3AF] hover:text-[#F4A7B9] dark:text-[#7070a0]"
                data-target="panel-related"
              >相关文章</button>
            )}
          </div>

          <!-- 目录面板 -->
          <div id="panel-toc" class="sidebar-panel overflow-y-auto flex-1">
            <TOC />
          </div>

          <!-- 相关文章面板 -->
          {relatedPosts.length > 0 && (
            <div id="panel-related" class="sidebar-panel hidden overflow-y-auto flex-1 space-y-3">
              {relatedPosts.map(p => (
                <a
                  href={`/blog/${p.id}`}
                  class="block group"
                >
                  <p class="text-xs font-medium leading-snug text-[#2D2D2D] dark:text-[#FFFAF8]
                             group-hover:text-[#F4A7B9] dark:group-hover:text-[#D4919F]
                             transition-colors line-clamp-2">
                    {p.title}
                  </p>
                  <p class="text-[10px] text-[#9CA3AF] dark:text-[#7070a0] mt-0.5">
                    {new Date(p.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </p>
                  {p.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-1">
                      {p.tags.slice(0, 3).map(tag => (
                        <span class="text-[9px] px-1.5 py-0.5 rounded-full
                                     bg-[#FFF0EE] dark:bg-[#2a1520]
                                     text-[#F4A7B9] dark:text-[#D4919F]">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  // 侧边栏标签切换
  const tabs = document.querySelectorAll<HTMLButtonElement>('.sidebar-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.sidebar-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.target!;

      // 更新 tab 样式
      tabs.forEach(t => {
        const isActive = t.dataset.target === targetId;
        t.classList.toggle('text-[#F4A7B9]', isActive);
        t.classList.toggle('dark:text-[#D4919F]', isActive);
        t.classList.toggle('bg-[#FFF0EE]', isActive);
        t.classList.toggle('dark:bg-[#2a1520]', isActive);
        t.classList.toggle('text-[#9CA3AF]', !isActive);
        t.classList.toggle('dark:text-[#7070a0]', !isActive);
      });

      // 切换面板显示
      panels.forEach(panel => {
        panel.classList.toggle('hidden', panel.id !== targetId);
      });
    });
  });
</script>
