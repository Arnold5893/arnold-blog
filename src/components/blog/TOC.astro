---
/**
 * TOC.astro — 文章悬浮目录
 * 桌面端固定在右侧，移动端通过 PostLayout 隐藏
 * 目录条目由客户端 JS 动态扫描页面中的 h2/h3 生成
 */
---

<nav
  id="toc"
  class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto text-sm"
  aria-label="文章目录"
>
  <p class="text-xs font-semibold uppercase tracking-widest mb-3
            text-[#9CA3AF] dark:text-[#7070a0]">目录</p>
  <ul id="toc-list" class="space-y-1.5"></ul>
</nav>

<script>
  // 扫描文章正文中的 h2/h3，生成目录并高亮当前节
  const tocList = document.getElementById('toc-list')!;
  const headings = document.querySelectorAll('.prose-blog h2, .prose-blog h3');

  headings.forEach((h, i) => {
    // 保证每个标题有 id
    if (!h.id) h.id = `heading-${i}`;

    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent ?? '';
    a.className = [
      'block truncate transition-colors duration-200 text-[#9CA3AF] hover:text-[#F4A7B9]',
      h.tagName === 'H3' ? 'pl-3 text-xs' : 'text-sm font-medium',
    ].join(' ');
    li.appendChild(a);
    tocList.appendChild(li);
  });

  // IntersectionObserver 高亮当前可见标题
  const links = tocList.querySelectorAll<HTMLAnchorElement>('a');
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          links.forEach(l => l.classList.remove('text-[#F4A7B9]', 'font-semibold'));
          const active = tocList.querySelector<HTMLAnchorElement>(`a[href="#${entry.target.id}"]`);
          active?.classList.add('text-[#F4A7B9]', 'font-semibold');
        }
      });
    },
    { rootMargin: '-10% 0px -80% 0px' }
  );

  headings.forEach(h => observer.observe(h));
</script>
