---
/**
 * PostCard.astro — 文章卡片，用于列表页和首页最新文章
 */
import type { CollectionEntry } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, tags, description, cover } = post.data;

// 格式化日期
const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'short', day: 'numeric',
});

// 阅读时长（从 body 估算）
const readingTime = getReadingTime(post.body ?? '');
---

<a
  href={`/blog/${post.id}`}
  class="group block bg-[#FFF0EE] rounded-2xl overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border border-[#F3E8E8]"
>
  {cover && (
    <div class="w-full aspect-video overflow-hidden">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}

  <div class="p-5">
    <!-- 标签 -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map(tag => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-white text-[#F4A7B9]">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- 标题 -->
    <h3 class="text-base font-bold text-[#2D2D2D] group-hover:text-[#F4A7B9] transition-colors line-clamp-2 mb-2">
      {title}
    </h3>

    <!-- 摘要 -->
    <p class="text-sm text-[#9CA3AF] line-clamp-2 mb-4">{description}</p>

    <!-- 日期 + 阅读时长 -->
    <div class="flex items-center justify-between text-xs text-[#9CA3AF]">
      <span>{formattedDate}</span>
      <span>{readingTime}阅读</span>
    </div>
  </div>
</a>
