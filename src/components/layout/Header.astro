---
/**
 * Header.astro — 顶部导航栏，移动端支持汉堡菜单，支持明暗主题切换
 */
const navLinks = [
  { href: '/',         label: '首页' },
  { href: '/blog',     label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about',    label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50
  bg-[#FFFAF8]/90 dark:bg-[#0F0E17]/90
  backdrop-blur-sm
  border-b border-[#F3E8E8] dark:border-[#2a2a40]
  transition-colors duration-300">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- 博客名 -->
    <a href="/"
      class="text-xl font-bold font-['Playfair_Display',serif] transition-colors
             text-[#2D2D2D] dark:text-[#FFFAF8]
             hover:text-[#F4A7B9] dark:hover:text-[#D4919F]">
      Arnold
    </a>

    <!-- 桌面端导航 -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "text-sm transition-colors duration-200",
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? "text-[#F4A7B9] dark:text-[#D4919F] font-medium"
              : "text-[#9CA3AF] dark:text-[#a0a0c0] hover:text-[#2D2D2D] dark:hover:text-[#FFFAF8]"
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- 右侧：主题切换 + 移动端汉堡按钮 -->
    <div class="flex items-center gap-3">
      <!-- 明暗切换按钮 -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg transition-colors
               text-[#9CA3AF] dark:text-[#a0a0c0]
               hover:text-[#2D2D2D] dark:hover:text-[#FFFAF8]
               hover:bg-[#F3E8E8] dark:hover:bg-[#1A1A2E]"
        aria-label="切换明暗模式"
      >
        <!-- 太阳图标（暗色模式下显示，点击切换为亮色） -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          class="hidden">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- 月亮图标（亮色模式下显示，点击切换为暗色） -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- 移动端汉堡按钮 -->
      <button
        id="menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2
               text-[#2D2D2D] dark:text-[#FFFAF8]"
        aria-label="打开菜单"
      >
        <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar1"></span>
        <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar2"></span>
        <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- 移动端展开菜单 -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden
           border-t border-[#F3E8E8] dark:border-[#2a2a40]
           bg-[#FFFAF8] dark:bg-[#0F0E17]"
  >
    <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "text-base transition-colors duration-200",
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? "text-[#F4A7B9] dark:text-[#D4919F] font-medium"
              : "text-[#9CA3AF] dark:text-[#a0a0c0] hover:text-[#2D2D2D] dark:hover:text-[#FFFAF8]"
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  // ---- 移动端菜单 ----
  const btn  = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let menuOpen = false;

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    menu?.classList.toggle('hidden', !menuOpen);
    if (menuOpen) {
      bar1!.style.transform = 'translateY(8px) rotate(45deg)';
      bar2!.style.opacity   = '0';
      bar3!.style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      bar1!.style.transform = '';
      bar2!.style.opacity   = '';
      bar3!.style.transform = '';
    }
  });

  // ---- 主题切换 ----
  const toggleBtn = document.getElementById('theme-toggle');
  const iconSun   = document.getElementById('icon-sun');
  const iconMoon  = document.getElementById('icon-moon');

  /** 根据当前 html.dark 状态更新图标显示 */
  function syncIcon(): void {
    const isDark = document.documentElement.classList.contains('dark');
    iconSun!.classList.toggle('hidden', !isDark);
    iconMoon!.classList.toggle('hidden', isDark);
  }

  /** 切换主题并持久化到 localStorage */
  function toggleTheme(): void {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncIcon();
    // 通知 Giscus 等子组件更新主题
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { dark: isDark } }));
  }

  toggleBtn?.addEventListener('click', toggleTheme);

  // 初始同步图标状态
  syncIcon();
</script>
