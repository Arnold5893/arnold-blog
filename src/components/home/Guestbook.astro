---
/**
 * Guestbook.astro — 首页留言区（复用 Giscus，映射到固定 key）
 */
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16 z-10 relative">
  <h2 class="text-2xl font-bold text-[#2D2D2D] font-['Playfair_Display',serif] mb-2">留言板</h2>
  <p class="text-sm text-[#9CA3AF] mb-6">欢迎留下你的足迹 ✨</p>

  <script
    src="https://giscus.app/client.js"
    data-repo="Arnold5893/blog-comments"
    data-repo-id="R_kgDORuR-Ng"
    data-category="Announcements"
    data-category-id="DIC_kwDORuR-Ns4C5Ezb"
    data-mapping="specific"
    data-term="guestbook"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
  ></script>
</section>
