---
/**
 * RecentPosts.astro — 首页最新文章列表（展示最近 5 篇）
 */
import { getCollection } from 'astro:content';
import PostCard from '../blog/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

{posts.length > 0 && (
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 z-10 relative">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold font-['Playfair_Display',serif]
                 text-[#2D2D2D] dark:text-[#FFFAF8]">
        最新文章
      </h2>
      <a href="/blog" class="text-sm hover:underline text-[#F4A7B9] dark:text-[#D4919F]">
        查看全部 →
      </a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map(post => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
)}
