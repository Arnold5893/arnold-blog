---
/**
 * 404.astro — 404 页面
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="404 页面未找到" description="页面不存在">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="animate-float mb-8">
      <img
        src="/images/hero.jpg"
        alt="迷路的立绘"
        class="w-48 object-contain drop-shadow-xl opacity-80"
      />
    </div>
    <h1 class="text-6xl font-bold text-[#F4A7B9] font-['Playfair_Display',serif] mb-4">404</h1>
    <p class="text-xl text-[#2D2D2D] mb-2">这个页面好像不见了……</p>
    <p class="text-[#9CA3AF] mb-8">也许它去喝茶了……</p>
    <a
      href="/"
      class="px-6 py-3 rounded-full bg-[#F4A7B9] text-white text-sm hover:bg-[#e8799a] transition-colors duration-200"
    >
      回到首页
    </a>
  </div>
</BaseLayout>