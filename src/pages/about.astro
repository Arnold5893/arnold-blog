---
/**
 * about.astro — 关于我页面
 */
import BaseLayout from '../components/layout/BaseLayout.astro';

const skills: string[] = [];

// 技术标签，手动编辑此数组即可更新页面
const learning = ['操作系统', 'C语言', 'Vue', 'JavaScript', 'MongoDB', 'Shell'];

// 普通书目（乳白色气泡）
const booksGeneral = ['《被讨厌的勇气》', '《认知觉醒》', '《山月记》', '《愿你可以自在张扬》'];
// CS 类书目（浅灰绿色气泡）
const booksCS = ['《CSAPP》', '《操作系统导论》'];
---

<BaseLayout title="About" description="关于">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- 头部：头像 + 简介 -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-12">
      <img
        src="/images/avatar.jpg"
        alt="Arnold 头像"
        class="w-28 h-28 rounded-full object-cover border-4 border-[#F3E8E8] shadow-md shrink-0"
      />
      <div class="text-center sm:text-left">
        <h1 class="text-3xl font-bold text-[#2D2D2D] font-['Playfair_Display',serif] mb-2">Arnold</h1>
        <p class="text-[#9CA3AF] mb-4">一只笨蛋脆脆鼠</p>
        <p class="text-[#2D2D2D] leading-relaxed">
          Hi, I'm Arnold. This blog is where I document my studies and thoughts. Feel free to communicate with me!<br />
        </p>
      </div>
    </div>

    <hr class="border-[#F3E8E8] mb-10" />

    <!-- 技术栈 -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-[#2D2D2D] mb-4">技术栈</h2>
      {skills.length > 0 ? (
        <div class="flex flex-wrap gap-2">
          {skills.map(s => (
            <span class="px-3 py-1.5 rounded-full bg-[#FFF0EE] text-sm text-[#2D2D2D] border border-[#F3E8E8]">{s}</span>
          ))}
        </div>
      ) : (
        <p class="text-sm text-[#9CA3AF]">持续学习中，敬请期待……</p>
      )}
    </section>

    <!-- 标签栏 -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-[#2D2D2D] mb-4">标签栏</h2>
      <div class="bg-[#F7EFEE] rounded-2xl shadow-sm border border-[#EDE2E2] px-6 py-5">
        <div class="flex flex-wrap items-baseline gap-x-5 gap-y-3">
          {learning.map((item, i) => {
            // 预定义尺寸、颜色、偏移，制造自然错落感
            const sizes  = ['text-base', 'text-sm', 'text-lg', 'text-xs', 'text-base', 'text-sm'];
            const colors = ['text-[#8C7070]', 'text-[#A08080]', 'text-[#6E6060]', 'text-[#B09090]', 'text-[#7A6868]', 'text-[#998080]'];
            const shifts = ['translate-y-0', 'translate-y-1', '-translate-y-0.5', 'translate-y-0.5', '-translate-y-1', 'translate-y-0'];
            return (
              <span class={`font-medium tracking-wide ${sizes[i % sizes.length]} ${colors[i % colors.length]} ${shifts[i % shifts.length]}`}>
                {item}
              </span>
            );
          })}
        </div>
      </div>
    </section>

    <!-- 读过/在读书目 -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-[#2D2D2D] mb-4">读过 / 在读</h2>
      <div class="flex flex-wrap gap-2">
        {booksGeneral.map(b => (
          <span class="px-3 py-1.5 rounded-full bg-[#F8F6F4] text-sm text-[#2D2D2D] border border-[#E8E4E0]">{b}</span>
        ))}
        {booksCS.map(b => (
          <span class="px-3 py-1.5 rounded-full bg-[#EBEBEB] text-sm text-[#2D2D2D] border border-[#D5D5D5]">{b}</span>
        ))}
      </div>
    </section>

    <!-- 社交链接 -->
    <section>
      <h2 class="text-xl font-bold text-[#2D2D2D] mb-4">联系我</h2>
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="https://github.com/Arnold5893"
          target="_blank" rel="noopener"
          class="flex items-center gap-3 px-5 py-3 rounded-xl bg-[#FFF0EE] border border-[#F3E8E8] hover:border-[#F4A7B9] transition-colors"
        >
          <svg class="w-5 h-5 text-[#2D2D2D]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="text-sm text-[#2D2D2D]">Arnold5893 on GitHub</span>
        </a>
        <a
          href="mailto:19712063060@163.com"
          class="flex items-center gap-3 px-5 py-3 rounded-xl bg-[#FFF0EE] border border-[#F3E8E8] hover:border-[#F4A7B9] transition-colors"
        >
          <svg class="w-5 h-5 text-[#2D2D2D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="text-sm text-[#2D2D2D]">19712063060@163.com</span>
        </a>
        <!-- 微信 -->
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl bg-[#FFF0EE] border border-[#F3E8E8]">
          <svg class="w-5 h-5 text-[#2D2D2D]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.063-6.122zm-3.19 3.158c.528 0 .956.435.956.972a.964.964 0 0 1-.956.972.964.964 0 0 1-.955-.972c0-.537.428-.972.955-.972zm6.376 0c.528 0 .956.435.956.972a.964.964 0 0 1-.956.972.964.964 0 0 1-.955-.972c0-.537.428-.972.955-.972z"/>
          </svg>
          <span class="text-sm text-[#2D2D2D]">WeChat：z19712063060</span>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>